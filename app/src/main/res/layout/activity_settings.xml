<?xml version="1.0" encoding="utf-8"?>
<!-- MD3 Settings Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md3_surface"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/md3_surface"
        android:paddingStart="4dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/md3_on_surface"
        app:title="Settings"
        app:titleTextColor="@color/md3_on_surface"
        app:subtitleTextColor="@color/md3_on_surface_variant" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md3_outline_variant" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- Section: Engine -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:text="ENGINE"
                android:textColor="@color/md3_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <!-- Multi Account (Accounts) -->
            <LinearLayout
                android:id="@+id/settings_accounts"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_account"
                    android:tint="@color/md3_on_surface_variant" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Multi Accounts" style="@style/SettingsItemText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Manage virtual user accounts" style="@style/SettingsSubText" />
                </LinearLayout>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_forward" android:tint="@color/md3_outline" />
            </LinearLayout>

            <!-- Virtual Location -->
            <LinearLayout
                android:id="@+id/settings_location"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_location"
                    android:tint="@color/md3_on_surface_variant" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Virtual Location" style="@style/SettingsItemText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Spoof GPS per app" style="@style/SettingsSubText" />
                </LinearLayout>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_forward" android:tint="@color/md3_outline" />
            </LinearLayout>

            <!-- Section: Performance -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
                android:background="@color/md3_outline_variant" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:text="PERFORMANCE"
                android:textColor="@color/md3_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <!-- Kill All -->
            <LinearLayout
                android:id="@+id/settings_kill_all"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_speed_up"
                    android:tint="@color/md3_on_surface_variant" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kill All Apps" style="@style/SettingsItemText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Free memory from all virtual apps" style="@style/SettingsSubText" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Google Services -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
                android:background="@color/md3_outline_variant" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:text="GOOGLE SERVICES"
                android:textColor="@color/md3_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <!-- GMS -->
            <LinearLayout
                android:id="@+id/settings_gms"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_google"
                    android:tint="@color/md3_on_surface_variant" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Google Play Services" style="@style/SettingsItemText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Install GMS framework inside virtual env" style="@style/SettingsSubText" />
                </LinearLayout>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_forward" android:tint="@color/md3_outline" />
            </LinearLayout>

            <!-- Section: Danger Zone -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
                android:background="@color/md3_outline_variant" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:text="SYSTEM"
                android:textColor="@color/md3_error"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <!-- Exit -->
            <LinearLayout
                android:id="@+id/settings_exit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_crash"
                    android:tint="@color/md3_error" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Exit Engine" style="@style/SettingsItemText" android:textColor="@color/md3_error"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Stop all virtual processes" style="@style/SettingsSubText" />
                </LinearLayout>
            </LinearLayout>

            <!-- About -->
            <LinearLayout
                android:id="@+id/settings_about"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_about"
                    android:tint="@color/md3_on_surface_variant" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="About" style="@style/SettingsItemText" />
                    <TextView android:id="@+id/settings_version_text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GANDA PLUS v3.3.0" style="@style/SettingsSubText" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
