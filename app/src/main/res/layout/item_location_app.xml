<?xml version="1.0" encoding="utf-8"?>
<!-- MD3 AMOLED Location App Item Card — identical rounding/elevation to item_launcher_app -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#131821"
    app:cardCornerRadius="22dp"
    app:cardElevation="8dp"
    android:outlineAmbientShadowColor="#004D64"
    android:outlineSpotShadowColor="#1A4FC3F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- App Icon -->
        <ImageView
            android:id="@+id/item_app_icon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:scaleType="fitCenter"
            tools:src="@mipmap/ic_launcher" />

        <!-- Text group -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <!-- App Name -->
            <TextView
                android:id="@+id/item_app_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E2E2E9"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Grab" />

            <!-- Location value — blue when spoofed, grey when real -->
            <TextView
                android:id="@+id/item_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#9BA4B4"
                android:textSize="12sp"
                tools:text="📍 -6.20188, 106.84561" />

        </LinearLayout>

        <!-- Chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#4FC3F7"
            android:textSize="24sp"
            android:paddingStart="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>