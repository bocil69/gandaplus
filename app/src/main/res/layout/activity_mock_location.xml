<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:map="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md3_surface">

    <com.google.android.gms.maps.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        map:mapType="normal" />

    <View
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_mock_location_top_scrim" />

    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_mock_location_bottom_scrim" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="68dp"
        app:cardBackgroundColor="@color/md3_surface_container"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeColor="@color/md3_outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel_action"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/md3_on_surface" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mock_location_title"
                    android:textColor="@color/md3_on_surface_variant"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_md3_input_field">

                    <androidx.appcompat.widget.SearchView
                        android:id="@+id/search_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:maxWidth="999dp"
                        android:theme="@style/ThemeOverlay.AppCompat.Dark"
                        app:iconifiedByDefault="false"
                        app:queryBackground="@null"
                        app:queryHint="@string/mock_location_search_hint"
                        app:searchIcon="@null" />
                </FrameLayout>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_search_action"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/shape_search_action_bg"
                android:backgroundTint="@color/md3_primary"
                android:contentDescription="@string/search"
                android:padding="10dp"
                android:src="@drawable/ic_search_white_24dp"
                app:tint="@color/md3_on_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/img_loc"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:layout_marginTop="74dp"
        android:background="@drawable/bg_mock_location_metric_card"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/selector_map_loc" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="88dp"
        android:background="@drawable/bg_mock_location_metric_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="7dp"
        android:paddingEnd="14dp"
        android:paddingBottom="7dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mock_location_drag_hint"
            android:textColor="@color/md3_on_surface"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/img_center_market"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|center_horizontal"
            android:scaleType="fitCenter"
            android:src="@drawable/map_select_location" />
    </FrameLayout>

    <!-- Bottom info card (compact) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_point"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="72dp"
        app:cardBackgroundColor="@color/md3_surface_container"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/md3_outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/layout_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- Header row: chip + status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_mock_location_section_chip"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="@string/mock_location_selected_address"
                    android:textColor="@color/md3_primary"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/img_mock"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/selector_mock"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/tv_mock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/no_mock"
                    android:textColor="@color/md3_on_surface_variant"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Address -->
            <TextView
                android:id="@+id/tv_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/unknown_location"
                android:textColor="@color/md3_on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Coordinate row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_lat"
                    android:textColor="@color/md3_primary"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_lat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="-"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_lng"
                    android:textColor="@color/md3_primary"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_lng"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="-"
                    android:textAlignment="viewEnd"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Utility buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_manual_input"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/title_input_location"
                    android:textAllCaps="false"
                    android:textColor="@color/md3_primary"
                    android:textSize="11sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_search_white_24dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:iconSize="14dp"
                    app:iconTint="@color/md3_primary" />

                <Space
                    android:layout_width="6dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_use_original"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/use_original_location"
                    android:textAllCaps="false"
                    android:textColor="@color/md3_on_surface_variant"
                    android:textSize="11sp"
                    app:cornerRadius="16dp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_location"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/save_location_point_only"
                    android:textAllCaps="false"
                    android:textColor="@color/md3_on_surface_variant"
                    android:textSize="11sp"
                    app:cornerRadius="16dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Prominent Play / Activate button — standalone at bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/img_go_mock"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/start_fake_location"
        android:textAllCaps="false"
        android:textColor="@color/md3_on_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/md3_primary"
        app:cornerRadius="26dp"
        app:elevation="6dp"
        app:icon="@drawable/map_postion_green"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconSize="20dp"
        app:iconTint="@color/md3_on_primary"
        app:rippleColor="#33FFFFFF" />

    <LinearLayout
        android:id="@+id/search_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="72dp"
        android:background="#A6000000"
        android:gravity="top"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardBackgroundColor="@color/md3_surface_container"
            app:cardCornerRadius="22dp"
            app:cardElevation="14dp"
            app:strokeColor="@color/md3_outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/mock_location_search_results"
                    android:textColor="@color/md3_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_tip_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="10dp"
                    android:text="@string/tip_search_keyword"
                    android:textColor="@color/md3_on_surface_variant"
                    android:textSize="12sp" />

                <io.virtualapp.widgets.ListViewPlus
                    android:id="@+id/search_results"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:divider="@color/md3_outline_variant"
                    android:dividerHeight="1dp"
                    android:listSelector="@android:color/transparent"
                    android:paddingBottom="6dp"
                    android:scrollbars="none" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
